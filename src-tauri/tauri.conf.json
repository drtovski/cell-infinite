{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CELL INFINITE",
  "version": "0.1.0",
  "identifier": "app.cellinfinite.game",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CELL: INFINITE",
        "width": 1440,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Game",
    "shortDescription": "An idle energy-cell reactor.",
    "longDescription": "Build a beautiful, automated energy-cell reactor. Level cells, wire synergies, rebirth for permanent power, and chase astronomical production.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
